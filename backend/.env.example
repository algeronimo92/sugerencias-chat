# Cadena de conexión a tu PostgreSQL existente
DATABASE_URL=postgresql+asyncpg://usuario:password@localhost:5432/nombre_db

# URL del webhook de n8n que procesa las sugerencias
N8N_WEBHOOK_URL=https://n8n.dermicapro.online/webhook-test/0e50def2-d86d-4d7c-987a-b76a71518cdf

# Token de autenticación del webhook (dejar vacío si no aplica)
N8N_WEBHOOK_TOKEN=

# Token que n8n debe enviar en el header X-Webhook-Token al llamar POST /api/webhooks/messages
# (dejar vacío para no exigir autenticación en ese endpoint)
INBOUND_WEBHOOK_TOKEN=

# Orígenes permitidos para CORS (separados por coma en lista Python)
# CORS_ORIGINS=["http://localhost:5173","https://tudominio.com"]
