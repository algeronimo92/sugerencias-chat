# Cadena de conexión a tu PostgreSQL existente
DATABASE_URL=postgresql+asyncpg://usuario:password@localhost:5432/nombre_db

# URL del webhook de n8n que procesa las sugerencias
N8N_WEBHOOK_URL=https://n8n.dermicapro.online/webhook-test/0e50def2-d86d-4d7c-987a-b76a71518cdf

# Token de autenticación del webhook (dejar vacío si no aplica)
N8N_WEBHOOK_TOKEN=

# Token que n8n debe enviar en el header X-Webhook-Token al llamar POST /api/webhooks/messages
# (dejar vacío para no exigir autenticación en ese endpoint)
INBOUND_WEBHOOK_TOKEN=

# Orígenes permitidos para CORS (separados por coma en lista Python)
# CORS_ORIGINS=["http://localhost:5173","https://tudominio.com"]

# Evolution API, para mandar mensajes de WhatsApp directo desde esta app
# (sin pasar por n8n). Dejar vacío deshabilita el envío.
EVOLUTION_API_URL=https://tu-evolution-api.dominio.com
EVOLUTION_API_KEY=
EVOLUTION_INSTANCE=nombre-de-tu-instancia

# ElevenLabs, para convertir a voz las sugerencias de texto y mandarlas como
# nota de audio de WhatsApp. Dejar ELEVENLABS_API_KEY vacío deshabilita
# "Enviar como audio". ELEVENLABS_VOICE_ID trae una voz por default (podés
# cambiarla eligiendo otra en https://elevenlabs.io/app/voice-library).
ELEVENLABS_API_KEY=
# ELEVENLABS_VOICE_ID=JBFqnCBsd6RMkjVDRZzb
# ELEVENLABS_MODEL_ID=eleven_multilingual_v2
# ELEVENLABS_STABILITY=0
# ELEVENLABS_STYLE=1
# ELEVENLABS_SPEED=1.2
# ELEVENLABS_USE_SPEAKER_BOOST=true

# Firma de los JWT de sesión de login. Generar con: openssl rand -hex 32
SECRET_KEY=

# Clave maestra para cifrar tokens y API keys guardados en app_settings.
# Generar una vez, respaldarla fuera de la DB y no cambiarla sin rotación:
# python -c "import base64,secrets; print(base64.urlsafe_b64encode(secrets.token_bytes(32)).decode())"
# Si se omite, el backend deriva temporalmente una clave de SECRET_KEY.
SETTINGS_ENCRYPTION_KEY=

# Se usan una única vez, para crear el primer usuario admin cuando la tabla
# `users` está vacía. Después de loguearte por primera vez podés borrar estas
# dos líneas (ya no se vuelven a leer si existe algún usuario).
ADMIN_EMAIL=
ADMIN_PASSWORD=

# Almacenamiento multimedia. Mantener "local" hasta que el bucket esté listo.
# MINIO_ENDPOINT es host[:puerto], sin http:// ni https://, y debe apuntar a
# la API S3 de MinIO (normalmente 9000), no a la consola administrativa.
MEDIA_STORAGE_BACKEND=local
MINIO_ENDPOINT=minio-api.tudominio.com:9000
MINIO_ACCESS_KEY=
MINIO_SECRET_KEY=
MINIO_BUCKET=dermicapro-media
MINIO_REGION=us-east-1
MINIO_SECURE=true
MINIO_VERIFY_TLS=true
# Objetos resultantes: dermicapro/images/*, dermicapro/audio/*,
# dermicapro/video/* y dermicapro/files/*.
MINIO_PREFIX=dermicapro
